{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ES2020",
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "lib": ["ES2020"],
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*", "src/index.ts"],
  "exclude": ["node_modules", "dist", ".vscode"]
}
